local function ProcessRaidPacket(pkt)
    if type(pkt) ~= "table" then return end
    local action = pkt.action and tostring(pkt.action):lower() or ""
    local isAdd = action:find("add") or action:find("update")
    local isRemove = action:find("remove") or action:find("delete")

    local dataList = pkt.raidInfos or pkt.data or pkt.infos
    if not dataList then
        for _, v in pairs(pkt) do
            if type(v) == "table" and type(v[1]) == "table" and v[1].mapId then
                dataList = v; break
            end
        end
    end

    if type(dataList) == "table" then
        if isAdd then
            for _, i in pairs(dataList) do if i.mapId then ActiveRaids[i.mapId] = i end end
        elseif isRemove then
            for _, i in pairs(dataList) do if i.mapId then ActiveRaids[i.mapId] = nil end end
        end
    end
end

