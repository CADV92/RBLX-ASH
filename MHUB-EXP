        Btn.Size = UDim2.new(1, 0, 1, 0)
        Btn.BackgroundTransparency = 1
        Btn.Text = ""

        local function UpdateValue(val)
            val = math.clamp(val, min, max)
            local pos = (val - min) / (max - min)
            Fill.Size = UDim2.new(pos, 0, 1, 0)
            Lbl.Text = text .. ": " .. val
