local function SoloRegistrar()
    if MinutosIngresados > 0 then
        local tiempoActual = os.time()
        local servidores = ObtenerServidoresGuardados()
        local servidoresActivos = {}
        
        for _, srv in ipairs(servidores) do
            -- Damos un margen de 10 minutos (-600 segundos) antes de borrarlos al guardar uno nuevo
            if (srv.SavedAt + (srv.Minutes * 60)) - tiempoActual >= -600 then
                table.insert(servidoresActivos, srv)
            end
        end

        table.insert(servidoresActivos, { JobId = game.JobId, SavedAt = tiempoActual, Minutes = MinutosIngresados })

        if writefile then
            pcall(function() writefile(TimersFileName, HttpService:JSONEncode(servidoresActivos)) end)
            StarterGui:SetCore("SendNotification", { Title = "Registrado", Text = "Servidor guardado con " .. MinutosIngresados .. " min.", Duration = 3 })
        end
    else
        StarterGui:SetCore("SendNotification", { Title = "Aviso", Text = "Ingresa minutos (>0) para registrar el servidor.", Duration = 3 })
    end
end

