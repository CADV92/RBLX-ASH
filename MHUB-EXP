                -- Obtenemos el estado actual leyendo ambos formatos
                local currentState = configTable[key]
                if currentState == nil and tonumber(key) then currentState = configTable[tonumber(key)] end
                if currentState == nil then currentState = configTable[tostring(key)] end
                
