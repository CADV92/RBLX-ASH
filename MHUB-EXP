local function ParseRaidID(mapId, raidId)
    local mapIndex = mapId
    if mapId > 50000 and mapId < 60000 then mapIndex = mapId - 50000 end
    
    local isAsc = false; local lvlRaw = 1
    if raidId and raidId >= 935000 then 
        isAsc = true; lvlRaw = raidId - 935000 - (mapIndex * 100) 
    elseif raidId and raidId >= 930000 then 
        isAsc = false; lvlRaw = raidId - 930000 - ((mapIndex - 1) * 10) 
    end
    
    if lvlRaw < 1 then lvlRaw = 1 end
    local rankStr = isAsc and (RanksMapASC[lvlRaw] or "?") or (RanksMapNormal[lvlRaw] or "S")
    return mapIndex, rankStr, isAsc
end

