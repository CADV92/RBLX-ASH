local function HandleRaidRewardUI()
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui then return false end
    local raidPanel = pGui:FindFirstChild("RaidsFightPanel")
    if raidPanel then
        local handled = false
        local settlement = raidPanel:FindFirstChild("SettlementFrame")
        local defeatFrame = raidPanel:FindFirstChild("Defeat")
        
        -- Refuerzo del cobro por si el trigger principal falló
        pcall(function() ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("GainRaidsRewards"):InvokeServer({1}) end)
        
        if settlement and settlement.Visible then
            local btn = settlement:FindFirstChild("CloseBtn") or settlement:FindFirstChild("ConfirmBtn")
            if btn and btn.Visible then
                handled = true
                if type(getconnections) == "function" then
                    pcall(function() 
                        for _, conn in pairs(getconnections(btn.MouseButton1Click)) do conn:Fire() end 
                        for _, conn in pairs(getconnections(btn.Activated)) do conn:Fire() end 
                    end)
                end
                settlement.Visible = false 
            end
        end
        
        if defeatFrame and defeatFrame.Visible then
            local confirmBtn = defeatFrame:FindFirstChild("ConfirmButton")
            if confirmBtn and confirmBtn.Visible then
                handled = true
                if type(getconnections) == "function" then
                    pcall(function() 
                        for _, conn in pairs(getconnections(confirmBtn.MouseButton1Click)) do conn:Fire() end 
                        for _, conn in pairs(getconnections(confirmBtn.Activated)) do conn:Fire() end 
                    end)
                end
                defeatFrame.Visible = false 
            end
        end
        
        if handled then
            if LblRaidStatus then LblRaidStatus.Text = "🎁 FINALIZADO / LIMPIANDO UI" end
            local fightFrame = raidPanel:FindFirstChild("FightFrame")
            if fightFrame then fightFrame.Visible = false end
            raidPanel.Enabled = false 
            return true
        end
    end
    return false
end

