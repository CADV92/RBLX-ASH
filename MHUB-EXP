local function GetBestGlobalRaid()
    local best, bestScore, count = nil, -1, 0
    for mapId, info in pairs(ActiveRaids) do
        if (info.endTime - os.time()) < 10 then continue end
        count = count + 1
        
        local mapIdx = mapId > 50000 and (mapId - 50000) or mapId
        
        -- FIX 1: Lógica blindada igual a ParseRaidID (evita que lvlRaw sea 0 o negativo)
        local isAsc = false; local lvlRaw = 1
        if info.raidId and info.raidId >= 935000 then 
            isAsc = true; lvlRaw = info.raidId - 935000 - (mapIdx * 100)
        elseif info.raidId and info.raidId >= 930000 then 
            isAsc = false; lvlRaw = info.raidId - 930000 - ((mapIdx - 1) * 10) 
        end
        if lvlRaw < 1 then lvlRaw = 1 end
        
        local rankStr = isAsc and (RanksMapASC[lvlRaw] or "?") or (RanksMapNormal[lvlRaw] or "S")
        local modeStr = isAsc and "A" or "N"
        local raidKey = modeStr .. "-" .. tostring(mapIdx) .. "-" .. rankStr
        
        -- FIX 2: Chequeo de mapas dual. Soporta la lectura del config como String y como Int (JSON safety)
        if not Config.RaidSettings.AllowedMaps[mapIdx] and not Config.RaidSettings.AllowedMaps[tostring(mapIdx)] then continue end
        
        -- Validadores de Grado y Modalidad
        if isAsc and not Config.RaidSettings.AllowedGradesASC[rankStr] then continue end
        if not isAsc and not Config.RaidSettings.AllowedGradesNormal[rankStr] then continue end
        if isAsc and not Config.RaidSettings.AllowedModes.ASC then continue end
        if not isAsc and not Config.RaidSettings.AllowedModes.Normal then continue end
        if Config.RaidSettings.Blacklist[raidKey] then continue end

        -- Evaluadores Especiales
        local isVip, vipRank = false, 0
        local runeKey = isAsc and ("ASC_" .. rankStr) or rankStr
        local isRuneTarget = Config.RaidSettings.Runes[runeKey] and (Config.RaidSettings.Runes[runeKey] > 0)
        for idx, vKey in ipairs(Config.RaidSettings.VipList) do if raidKey == vKey then isVip = true; vipRank = idx; break end end

        -- Sistema de Scoring
        local score = 0
        if isAsc and mapIdx == 16 and (rankStr == "A" or rankStr == "C") then
            score = 200000000 -- Prioridad Absoluta (A-16)
        elseif isVip then 
            score = 100000000 - (vipRank * 10000)
        elseif isRuneTarget then
            score = 50000000
        else
            if isAsc then score = score + 10000000 end
            if Config.RaidSettings.Priority == "MAP" then
                score = score + (Config.RaidSettings.Order == "HIGHEST" and ((mapIdx * 100) + lvlRaw) or (((20 - mapIdx) * 100) + lvlRaw))
            else
                score = score + (Config.RaidSettings.Order == "HIGHEST" and ((lvlRaw * 1000) + mapIdx) or (((20 - lvlRaw) * 1000) + mapIdx))
            end
        end

        if score > bestScore then 
            bestScore = score; best = { info=info, mapIdx=mapIdx, rank=rankStr, isAsc=isAsc, runeKey=runeKey } 
        end
    end
    return best, count
end

local function HandleRaidCooldown(seconds)
    RaidState.CooldownActive = true
    task.spawn(function()
        local endT = tick() + seconds
        while tick() < endT and HubRunning do
            local rem = math.ceil(endT - tick())
            if Config.RaidSettings.AutoRaid then
                BtnAutoRaid.SetState(true, "⏳ CD: " .. rem .. "s")
            end
            task.wait(0.5)
        end
        RaidState.CooldownActive = false
        if Config.RaidSettings.AutoRaid then BtnAutoRaid.SetState(true, "🛑 DETENER AUTO RAID") end
    end)
end

