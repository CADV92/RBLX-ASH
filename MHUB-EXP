local ServidorSeleccionadoId = nil

TabCity:CreateDropdown("Servidores Disponibles", 
    function()
        local servidores = ObtenerServidoresGuardados()
        local tiempoActual = os.time()
        
        local servidoresConTiempo = {}

        for _, srv in ipairs(servidores) do
            local tiempoExpiracion = srv.SavedAt + (srv.Minutes * 60)
            local segundosRestantes = tiempoExpiracion - tiempoActual
            
            -- Margen de -10 minutos (-600 segundos) para mostrar en la lista
            if segundosRestantes >= -600 then
                table.insert(servidoresConTiempo, {
                    DataOriginal = srv,
                    Segundos = segundosRestantes
                })
            end
        end

        -- Ordenar de menor a mayor (los negativos saldrán primero)
        table.sort(servidoresConTiempo, function(a, b)
            return a.Segundos < b.Segundos
        end)

        local validOptions = {}
        local servidoresActivos = {}

        for _, item in ipairs(servidoresConTiempo) do
            table.insert(servidoresActivos, item.DataOriginal)
            
            local minutosRestantes = math.floor(item.Segundos / 60)
            local formatoLista = string.format("[%d min] ID: %s", minutosRestantes, item.DataOriginal.JobId:sub(1,8))
            
            table.insert(validOptions, {Name = formatoLista, Data = item.DataOriginal.JobId})
        end

        if writefile then
            pcall(function() writefile(TimersFileName, HttpService:JSONEncode(servidoresActivos)) end)
        end

        if #validOptions == 0 then
            table.insert(validOptions, {Name = "No hay servidores activos", Data = nil})
        end

        return validOptions
    end, 
    function(selectedData)
        ServidorSeleccionadoId = selectedData
    end
