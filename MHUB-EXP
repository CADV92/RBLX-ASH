local Utils = {}

function Utils.GetEnemyFolder()
    return Workspace:FindFirstChild("Enemys") or Workspace:FindFirstChild("Enemies") or Workspace:FindFirstChild("Mobs")
end

function Utils.GetGUID(model)
    if not model or typeof(model) ~= "Instance" then return nil end
    local attr = model:GetAttribute("GUID") or model:GetAttribute("guid") or model:GetAttribute("EnemyGuid")
    if attr then return attr end
    local valObj = model:FindFirstChild("GUID") or model:FindFirstChild("EnemyId")
    if valObj then return valObj.Value end
    return model.Name
end

function Utils.EstaMuerto(model)
    if not model or typeof(model) ~= "Instance" or not model.Parent or not model:FindFirstChild("HumanoidRootPart") then return true end
    local root = model.HumanoidRootPart
    if root:FindFirstChild("EnemyNameGui") and root.EnemyNameGui:FindFirstChild("Progress") and root.EnemyNameGui.Progress:FindFirstChild("HealthNum") then
        local txt = root.EnemyNameGui.Progress.HealthNum.Text
        if txt ~= "" and txt ~= "0" then return false end
        return true
    end
    local hum = model:FindFirstChild("Humanoid")
    if hum then return hum.Health <= 0 end
    return true
end

function Utils.EsMobValido(enemy, myRoot, limites)
    if Utils.EstaMuerto(enemy) then return false end
    local root = enemy:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local yPos = root.Position.Y
    if yPos < limites.MinHeight then return false end
    if math.abs(yPos - limites.BuggedHeight) < limites.BugTolerance then return false end
    return true
end

function Utils.ParseValue(str)
    if not str or str == "" then return 0 end
    if str:find("/") then str = str:split("/")[1] end
    local cleanStr = str:gsub("HP:", ""):gsub("Health:", ""):gsub("hp:", ""):gsub("%s+", ""):gsub(",", "")
    local valStr, sufStr = cleanStr:match("^([%d%.]+)(.*)$")
    if valStr then
        local num = tonumber(valStr) or 0
        if sufStr and sufStr ~= "" then local mult = ReadSuffixes[sufStr] or ReadSuffixes[string.upper(sufStr)]; if mult then return num * mult end end
        return num
    end return 0
end

function Utils.ParseDamageText(str)
    if not str or type(str) ~= "string" then return 0 end
    local cleanStr = string.gsub(str, "<[^>]+>", "")
    cleanStr = string.gsub(cleanStr, "[%+%-%s,]", "")
    local valStr, sufStr = string.match(cleanStr, "^([%d%.]+)(.*)$")
    if valStr then
        local num = tonumber(valStr) or 0
        if sufStr and sufStr ~= "" then 
            local mult = ReadSuffixes[sufStr] or ReadSuffixes[string.upper(sufStr)]
            if mult then return num * mult end 
        end
        return num
    end 
    return 0
end

function Utils.GetCurrentRealHealth(model)
    if not model then return 0 end
    local maxVal = 0
    for _, lbl in pairs(model:GetDescendants()) do
        if lbl:IsA("TextLabel") and lbl.Visible then
            local txt = lbl.Text
            if txt:match("%d") and not txt:find("Lvl") and not txt:find("Level") then
                local current = Utils.ParseValue(txt)
                if current > maxVal then maxVal = current end
            end
        end
    end
    return maxVal
end

