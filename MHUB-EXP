local TreeIDs = { ["base"]=1, ["sword"]=2, ["ice"]=3, ["blood"]=4, ["moon"]=5, ["easter"]=6, ["water"]=7, ["winter"]=8, ["jack"]=9, ["anni"]=10, ["KEEP"]=false }
local TreeCycleOpts = { "KEEP", "base", "sword", "ice", "blood", "moon", "easter", "water", "winter", "jack", "anni" }

local UseGem, OnekyUseGem = Remotes:WaitForChild("UseGem"), Remotes:WaitForChild("OnekyUseGem")
local EquipWeapon, BufferWeapon, UnbufferAll = Remotes:WaitForChild("EquipWeapon"), Remotes:WaitForChild("BufferWeapon"), Remotes:WaitForChild("UnbufferAllWeapon")
local EquipMount, BufferMount, UseHalo = Remotes:WaitForChild("EquipMount"), Remotes:WaitForChild("BufferMount"), Remotes:WaitForChild("UseHalo")
local EquipRespiration, BufferRespiration = Remotes:WaitForChild("EquipRespiration"), Remotes:WaitForChild("BufferRespiration")
local BufferHalo = Remotes:FindFirstChild("BufferHalo")

local function CambiarModoAutoEquip(nombre)
    local gear = Config.StaticGear[nombre]
    local tSet = Config.TreeSettings[nombre]
    if not gear or not tSet then return end
    EquipModeSelected = nombre

    local EquipTreeID = TreeIDs[tSet.Equip]
    local BuffTreeID = TreeIDs[tSet.Buff]
    local requiereGemas = (EquipTreeID or BuffTreeID) and (nombre == "ATAQUE" or nombre == "ORO" or nombre == "PODER")

    if requiereGemas then
        for i = 1, 9 do pcall(function() OnekyUseGem:InvokeServer({ isEquip = false, selectRespirationType = i }) end) end 
        task.wait(0.1) 
    end
    
    pcall(function() UnbufferAll:FireServer() end)

    if gear.Mounts and gear.Mounts.Equip then pcall(function() EquipMount:FireServer(gear.Mounts.Equip) end) end
    if gear.Mounts and gear.Mounts.Buff then pcall(function() BufferMount:FireServer(gear.Mounts.Buff) end) end

    if gear.Halos and gear.Halos.Equip then pcall(function() UseHalo:InvokeServer(gear.Halos.Equip) end) end
    if gear.Halos and gear.Halos.Buff and BufferHalo then pcall(function() BufferHalo:InvokeServer(gear.Halos.Buff) end) end

    if gear.Weapons then
        for _, uid in ipairs(gear.Weapons.Equip or {}) do pcall(function() EquipWeapon:FireServer(uid) end) task.wait(0.01) end
        for _, uid in ipairs(gear.Weapons.Buffer or {}) do pcall(function() BufferWeapon:FireServer(uid) end) task.wait(0.01) end
    end
    
    if EquipTreeID then pcall(function() EquipRespiration:FireServer(EquipTreeID) end) end
    if BuffTreeID then pcall(function() BufferRespiration:FireServer(BuffTreeID) end) end
    task.wait(0.1)

    if requiereGemas then
        local UsedIndices = { RED = 1, BLUE = 1, GREEN = 1, RAINBOW = 1 }
        local function EquipCustomSlot(treeId, slotSuffix, colorPref, defaultFallback)
            if not treeId then return end
            local S = SlotMath[treeId] if not S then return end
            local targetPool = colorPref
            if colorPref == "AUTO" then targetPool = defaultFallback end
            for i = 1, 9 do 
                local pool = Config.StaticGems[targetPool]
                local idx = UsedIndices[targetPool]
                if pool and pool[idx] then
                    local gemGuid = pool[idx]
                    UsedIndices[targetPool] = idx + 1
                    local positionStr = S[i] .. slotSuffix
                    pcall(function() UseGem:FireServer({guid = gemGuid, position = positionStr}) end)
                    if i % 3 == 0 then task.wait(0.01) end 
                end
            end
        end
        if EquipTreeID then
            EquipCustomSlot(EquipTreeID, "_1", Config.GemSettings.Principal.S1, "RED")
            EquipCustomSlot(EquipTreeID, "_2", Config.GemSettings.Principal.S2, nombre == "ORO" and "GREEN" or "RAINBOW")
            EquipCustomSlot(EquipTreeID, "_3", Config.GemSettings.Principal.S3, "BLUE")
            EquipCustomSlot(EquipTreeID, "_4", nombre == "ORO" and "GREEN" or Config.GemSettings.Principal.S4, "RED")
            task.wait(0.01)
        end
        if BuffTreeID then
            EquipCustomSlot(BuffTreeID, "_1", Config.GemSettings.Buff.S1, "RED")
            EquipCustomSlot(BuffTreeID, "_2", Config.GemSettings.Buff.S2, nombre == "ORO" and "GREEN" or "RAINBOW")
            EquipCustomSlot(BuffTreeID, "_3", Config.GemSettings.Buff.S3, "BLUE")
            EquipCustomSlot(BuffTreeID, "_4", nombre == "ORO" and "GREEN" or Config.GemSettings.Buff.S4, "RED")
        end
    end
    pcall(function() StarterGui:SetCore("SendNotification", { Title = "AutoEquip", Text = "¡" .. nombre .. " equipado!", Duration = 3 }) end)
end

local monitorConn = RunService.Heartbeat:Connect(function()
    local now = tick()
    if now - lastTick < 0.1 then return end 
    lastTick = now

    local char = LocalPlayer.Character
    local myRoot = char and char:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    if Config.AutoOroEnabled and EquipModeSelected == "ORO" then
        if TiempoInicioEspecial == 0 then TiempoInicioEspecial = now end
        if now - TiempoInicioEspecial >= TiempoRegresoAtaque then
            CambiarModoAutoEquip("ATAQUE")
            TiempoInicioEspecial = 0
        end
    else
        TiempoInicioEspecial = 0
    end

    if CurrentTarget then
        local isDestroyed = not CurrentTarget.Parent
        local currentHP = isDestroyed and 0 or Utils.GetCurrentRealHealth(CurrentTarget)
        
        if isDestroyed or currentHP <= DeadHpThreshold then
            if enemyHPTracker[CurrentTarget] ~= nil then
                if Config.AutoOroEnabled then
                    if EquipModeSelected ~= "ORO" then
                        AutoUseGoldPotions() 
                        CambiarModoAutoEquip("ORO")
                    end
                    TiempoInicioEspecial = now
                elseif Config.AutoDropEnabled then
                    task.delay(2, function()
                        if EquipModeSelected == "DROP" then CambiarModoAutoEquip("ATAQUE") end
                    end)
                end
            end
            CurrentTarget = nil 
        end
    end

    local enemiesFolder = Workspace:FindFirstChild("Enemys")
    local activeAttackedTarget = nil
    local closestEnemy = nil
    local bestDist = SearchRadius 

    if enemiesFolder then
        for _, obj in pairs(enemiesFolder:GetChildren()) do
            if obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") then
                local dist = (obj.HumanoidRootPart.Position - myRoot.Position).Magnitude
                if dist <= SearchRadius then
                    local hp = Utils.GetCurrentRealHealth(obj)
                    local lastHp = enemyHPTracker[obj]

                    if lastHp and hp < lastHp and hp > DeadHpThreshold then
                        activeAttackedTarget = obj
                    end
                    enemyHPTracker[obj] = hp 

                    if dist < bestDist and hp > DeadHpThreshold then
                        bestDist = dist
                        closestEnemy = obj 
                    end
                else
                    enemyHPTracker[obj] = nil 
                end
            end
        end
    end

    if activeAttackedTarget then CurrentTarget = activeAttackedTarget
    elseif not CurrentTarget and closestEnemy then CurrentTarget = closestEnemy end

    if CurrentTarget and CurrentTarget ~= PreviousTarget then
        TotalDamageDealt = 0
        if DamageLabel then DamageLabel.Text = "⚔️ DMG: 0" end
        PreviousTarget = CurrentTarget
    end

    if CurrentTarget then
        local hp = Utils.GetCurrentRealHealth(CurrentTarget)
        TargetLabel.Text = "🎯 " .. CurrentTarget.Name
        HpLabel.Text = "❤️ " .. Utils.FormatHealth(hp)
        
        if Config.AutoDropEnabled and hp <= AutoDropThreshold and hp > DeadHpThreshold then
            if EquipModeSelected ~= "DROP" then CambiarModoAutoEquip("DROP") end
        end
    else
        TargetLabel.Text = "🎯 NINGUNO"; HpLabel.Text = "❤️ 0"
    end
end)
