function Utils.ManualTeleportAndEnter(isSiege)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent and v.Parent:IsA("BasePart") then
            local parentName = v.Parent.Parent and v.Parent.Parent.Name or ""
            local matches = isSiege and parentName:find("CityRaidEnter") or (parentName:find("RaidEnter") and not parentName:find("City"))
            
            if matches then
                root.CFrame = v.Parent.CFrame
                task.wait(0.15)
                if type(fireproximityprompt) == "function" then 
                    fireproximityprompt(v) 
                else 
                    v:InputHoldBegin()
                    task.wait(v.HoldDuration + 0.1)
                    v:InputHoldEnd() 
                end
                return true
            end
        end
    end
    return false
end

-- Sanity Check
local LobbyPortalCache = nil
function Utils.EstaEnLobby(root)
    if not root then return false end
    
    -- Caché: Si ya lo encontramos antes, verificamos directo para ahorrar FPS
    if LobbyPortalCache and LobbyPortalCache.Parent then
        if (LobbyPortalCache.Position - root.Position).Magnitude < 5000 then 
            return true 
        end
    end

    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") and v.Parent and v.Parent.Parent and v.Parent.Parent.Name:find("RaidEnter") and not v.Parent.Parent.Name:find("City") then
            LobbyPortalCache = v.Parent
            if (v.Parent.Position - root.Position).Magnitude < 5000 then 
                return true 
            end
        end
    end
    return false
end

