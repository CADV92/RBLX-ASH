task.spawn(function()
    local overlapParams = OverlapParams.new(); overlapParams.FilterType = Enum.RaycastFilterType.Include
    while HubRunning do
        if Config.KillAura then
            local char = LocalPlayer.Character 
            local fld = Utils.GetEnemyFolder()
            if char and char:FindFirstChild("HumanoidRootPart") and fld then
                overlapParams.FilterDescendantsInstances = {fld}
                local rootPos = char.HumanoidRootPart.Position
                local partes = Workspace:GetPartBoundsInRadius(rootPos, Config.AuraRadio, overlapParams)
                
                local procesados, validos = {}, {}
                for _, part in pairs(partes) do
                    local enemy = part.Parent
                    if typeof(enemy) == "Instance" and enemy and not procesados[enemy] and enemy:FindFirstChild("HumanoidRootPart") then
                        procesados[enemy] = true
                        if not Utils.EstaMuerto(enemy) then
                            table.insert(validos, { modelo = enemy, dist = (rootPos - enemy.HumanoidRootPart.Position).Magnitude })
                        else
                            pcall(function() enemy.HumanoidRootPart.CFrame = CFrame.new(0, -50000, 0); enemy.HumanoidRootPart.Anchored = false end)
                        end
                    end
                end
                
                if Config.AuraModoSec then table.sort(validos, function(a, b) return a.dist < b.dist end) end
                local MAX = Config.AuraModoSec and 1 or 15
                
                for i = 1, math.min(MAX, #validos) do
                    local enemy = validos[i].modelo
                    local eGuid = Utils.GetGUID(enemy)
                    task.spawn(function() pcall(function()
                        if CEnemyRem then CEnemyRem:InvokeServer({ ["enemyGuid"] = eGuid, ["enemyCharacter"] = enemy }) end
                        if PAttackRem then PAttackRem:FireServer({ ["attackEnemyGUID"] = eGuid }); PAttackRem:FireServer({ ["autoClickEnemyGUID"] = eGuid }) end
                        if PAttackBase then PAttackBase:FireServer({ ["attackEnemyGUID"] = eGuid }) end
                    end) end)
                    if not Config.AuraModoSec then task.wait(0.05) end 
                end
            end
        end

        if Config.AutoRandom then
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if myRoot then
                if not AutoRandomState.Target or Utils.EstaMuerto(AutoRandomState.Target) then
                    AutoRandomState.Target = nil
                    local fld = Utils.GetEnemyFolder()
                    if fld then
                        local mobs = {}
                        for _, enemy in pairs(fld:GetChildren()) do
                            if Utils.EsMobValido(enemy, myRoot, LimitesMobsBase) then
                                table.insert(mobs, enemy)
                            end
                        end
                        if #mobs > 0 then
                            AutoRandomState.Target = mobs[math.random(1, #mobs)]
                        end
                    end
                end
                
                if AutoRandomState.Target and not Utils.EstaMuerto(AutoRandomState.Target) then
                    local targetRoot = AutoRandomState.Target:FindFirstChild("HumanoidRootPart")
                    if targetRoot then
                        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 5)
                        myRoot.AssemblyLinearVelocity = Vector3.zero
                        
                        local eGuid = Utils.GetGUID(AutoRandomState.Target)
                        if eGuid then
                            pcall(function()
                                if CEnemyRem then CEnemyRem:InvokeServer({ ["enemyGuid"] = eGuid, ["enemyCharacter"] = AutoRandomState.Target }) end
                                if PAttackRem then PAttackRem:FireServer({ ["attackEnemyGUID"] = eGuid }) end
                                if PAttackBase then PAttackBase:FireServer({ ["attackEnemyGUID"] = eGuid }) end
                            end)
                        end
                    end
                end
            end
        end

        task.wait(0.3)
    end
end)

